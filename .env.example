# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
LLM_GATEWAY_URL=http://10.0.0.224:11434/v1
LLM_GATEWAY_KEY=ollama
MODEL_GENERAL=qwen3:8b
MODEL_CODE=qwen2.5-coder:14b
MODEL_FAST=qwen2.5:1.5b

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DATABASE_URL=postgresql://agent:agent@localhost:5432/agent

# ── S3-compatible object storage (SeaweedFS default) ─────────────────────────
# Works with SeaweedFS, Ceph RGW, RustFS, or any S3-compatible endpoint.
# MINIO_* keys are accepted as fallback for backward compatibility.
S3_ENDPOINT=localhost:8333
S3_PUBLIC_ENDPOINT=localhost:8333   # public address for presigned URLs (defaults to S3_ENDPOINT)
S3_ACCESS_KEY=agent_access
S3_SECRET_KEY=agent_secret
S3_BUCKET=agent-vfs
S3_SECURE=false

# ── Kubernetes sandbox ────────────────────────────────────────────────────────
# AGENT_SANDBOX_BACKEND=kubernetes   # default — uses K8s Jobs
# AGENT_SANDBOX_BACKEND=local        # subprocess fallback (dev/test only)
AGENT_SANDBOX_NAMESPACE=agent-sandbox
AGENT_SANDBOX_IMAGE=python:3.12-slim
AGENT_SANDBOX_TIMEOUT=60
# KUBECONFIG=/path/to/kubeconfig     # only needed outside cluster

# ── Next.js UI ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
AGENT_URL=http://localhost:8000
